# =============================================================
# iaundang — Environment Variables
# Copy this to .env.local and fill in your values
# =============================================================

# Database (Prisma → Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Supabase (Storage & Auth)
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# JWT Session
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Admin
ADMIN_EMAIL="admin@iaundang.online"
NEXT_PUBLIC_ADMIN_EMAIL="admin@iaundang.online"

# App URL
NEXT_PUBLIC_APP_URL="https://iaundang.online"
NEXT_PUBLIC_APP_DOMAIN="iaundang.online"

# Email (Resend — optional, falls back to console log)
RESEND_API_KEY=""
EMAIL_FROM="IAUndang <noreply@iaundang.online>"

# Cron
CRON_SECRET=""

# Payment - Mayar
MAYAR_API_KEY=""
MAYAR_WEBHOOK_TOKEN=""
