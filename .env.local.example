# =============================================================
# iaundang — Environment Variables
# Copy file ini menjadi .env.local dan isi semua nilainya.
# =============================================================

# Supabase (wajib)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...   # RAHASIA — jangan commit!

# Payment - Mayar (nama variabel harus sama persis dengan lib/mayar.ts)
MAYAR_API_KEY=
MAYAR_WEBHOOK_TOKEN=

# App
NEXT_PUBLIC_APP_URL=https://iaundang.online
# NEXT_PUBLIC_APP_DOMAIN berbeda antar-environment:
#   Production      : iaundang.online
#   Staging (Preview): staging.iaundang.online
#   Local           : localhost
NEXT_PUBLIC_APP_DOMAIN=iaundang.online

# Admin (email yang bisa akses /admin)
ADMIN_EMAIL=admin@iaundang.online
NEXT_PUBLIC_ADMIN_EMAIL=admin@iaundang.online

# --- UNTUK DEVELOPMENT LOKAL ---
# Untuk simulasi subdomain lokal, gunakan ?slug=nama pada URL
# Contoh: http://localhost:3000?slug=budi-dan-ani
