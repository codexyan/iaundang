// iaundang DB Schema — PostgreSQL (Supabase)
// Dev: DATABASE_URL = direct connection Supabase
// Prod: DATABASE_URL = pooler (pgbouncer), DIRECT_URL = direct

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USERS ────────────────────────────────────────────────────
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         String   @default("user")
  referralCode String?  @unique @map("referral_code")
  createdAt    DateTime @default(now()) @map("created_at")

  invitations    Invitation[]
  paymentProofs  PaymentProof[]
  articles       Article[]
  affiliate      Affiliate?
  supportTickets SupportTicket[]
  referralsMade  UserReferral[] @relation("referrer")
  referralsFrom  UserReferral[] @relation("referred")

  @@map("users")
}

// ─── INVITATIONS ──────────────────────────────────────────────
model Invitation {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  slug        String    @unique
  templateId  String    @map("template_id")
  data        Json
  packageTier String?   @map("package_tier")
  isPublished Boolean   @default(false) @map("is_published")
  isPaid      Boolean   @default(false) @map("is_paid")
  referredBy  String?   @map("referred_by")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  galleries     Gallery[]
  guests        Guest[]
  wishes        Wish[]
  paymentProofs PaymentProof[]
  giftProofs    GiftProof[]
  views         InvitationView[]

  @@index([userId])
  @@map("invitations")
}

// ─── GALLERIES ────────────────────────────────────────────────
model Gallery {
  id           String @id @default(cuid())
  invitationId String @map("invitation_id")
  url          String
  order        Int    @default(0)

  invitation Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  @@index([invitationId])
  @@map("galleries")
}

// ─── GUESTS (unified: contact + RSVP) ────────────────────────
model Guest {
  id           String    @id @default(cuid())
  invitationId String    @map("invitation_id")
  name         String
  phone        String    @default("")
  group        String    @default("")
  note         String    @default("")
  source       String    @default("manual")
  attending    Boolean?
  totalGuests  Int       @default(1) @map("total_guests")
  blastSentAt  DateTime? @map("blast_sent_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  invitation Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  @@index([invitationId])
  @@map("guests")
}

// ─── WISHES ───────────────────────────────────────────────────
model Wish {
  id           String   @id @default(cuid())
  invitationId String   @map("invitation_id")
  name         String
  message      String
  createdAt    DateTime @default(now()) @map("created_at")

  invitation Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  @@index([invitationId])
  @@map("wishes")
}

// ─── TEMPLATE RECORDS (JSON-driven system) ────────────────────
model TemplateRecord {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  category        String
  config          Json
  thumbnailUrl    String   @default("") @map("thumbnail_url")
  status          String   @default("draft")
  sortOrder       Int      @default(0) @map("sort_order")
  usageCount      Int      @default(0) @map("usage_count")
  price           Int      @default(0)
  requiredPackage String   @default("all") @map("required_package")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("template_records")
}

// ─── PAYMENT PROOFS ───────────────────────────────────────────
model PaymentProof {
  id           String    @id @default(cuid())
  invitationId String    @map("invitation_id")
  userId       String    @map("user_id")
  orderId      String?   @map("order_id")
  userEmail    String    @map("user_email")
  slug         String
  amount       Int       @default(0)
  bankName     String    @default("") @map("bank_name")
  transferDate String    @default("") @map("transfer_date")
  proofUrl     String    @default("") @map("proof_url")
  notes        String    @default("")
  status       String    @default("pending")
  adminNotes   String    @default("") @map("admin_notes")
  createdAt    DateTime  @default(now()) @map("created_at")
  reviewedAt   DateTime? @map("reviewed_at")

  invitation Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([orderId])
  @@index([invitationId])
  @@map("payment_proofs")
}

// ─── GIFT PROOFS ──────────────────────────────────────────────
model GiftProof {
  id           String   @id @default(cuid())
  invitationId String   @map("invitation_id")
  name         String
  proofUrl     String   @map("proof_url")
  createdAt    DateTime @default(now()) @map("created_at")

  invitation Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  @@index([invitationId])
  @@map("gift_proofs")
}

// ─── MUSIC LIBRARY ───────────────────────────────────────────
model MusicTrack {
  id         String   @id @default(cuid())
  title      String
  artist     String   @default("")
  category   String   @default("Lainnya")
  url        String
  duration   Int      @default(0)
  fileSize   Int      @default(0) @map("file_size")
  isActive   Boolean  @default(true) @map("is_active")
  sortOrder  Int      @default(0) @map("sort_order")
  usageCount Int      @default(0) @map("usage_count")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("music_tracks")
}

// ─── MUSIC CATEGORIES ────────────────────────────────────────
model MusicCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("music_categories")
}

// ─── ARTICLES (Blog / Landing Page) ──────────────────────────
model Article {
  id             String    @id @default(cuid())
  title          String
  slug           String    @unique
  excerpt        String    @default("")
  content        String    @default("")
  coverUrl       String    @default("") @map("cover_url")
  authorId       String?   @map("author_id")
  authorName     String    @default("Tim iaundang") @map("author_name")
  authorAvatar   String    @default("") @map("author_avatar")
  isPublished    Boolean   @default(false) @map("is_published")
  publishedAt    DateTime? @map("published_at")
  allowLikes     Boolean   @default(true) @map("allow_likes")
  allowComments  Boolean   @default(true) @map("allow_comments")
  likesCount     Int       @default(0) @map("likes_count")
  viewsCount     Int       @default(0) @map("views_count")
  metaTitle      String    @default("") @map("meta_title")
  metaDesc       String    @default("") @map("meta_desc")
  tags           String    @default("")
  settings       Json      @default("{}")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  author User? @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([authorId])
  @@map("articles")
}

// ─── AFFILIATES ─────────────────────────────────────────────
model Affiliate {
  id             String   @id @default(cuid())
  userId         String   @unique @map("user_id")
  referralCode   String   @unique @map("referral_code")
  commissionRate Int      @default(10) @map("commission_rate")
  totalEarnings  Int      @default(0) @map("total_earnings")
  pendingBalance Int      @default(0) @map("pending_balance")
  paidBalance    Int      @default(0) @map("paid_balance")
  totalClicks    Int      @default(0) @map("total_clicks")
  totalConversions Int    @default(0) @map("total_conversions")
  isActive       Boolean  @default(true) @map("is_active")
  bankName       String   @default("") @map("bank_name")
  accountNo      String   @default("") @map("account_no")
  accountName    String   @default("") @map("account_name")
  createdAt      DateTime @default(now()) @map("created_at")

  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  referrals   Referral[]
  withdrawals AffiliateWithdrawal[]

  @@map("affiliates")
}

model Referral {
  id           String   @id @default(cuid())
  affiliateId  String   @map("affiliate_id")
  invitationId String?  @map("invitation_id")
  buyerEmail   String   @default("") @map("buyer_email")
  packageTier  String   @default("") @map("package_tier")
  saleAmount   Int      @default(0) @map("sale_amount")
  commission   Int      @default(0)
  status       String   @default("clicked")
  createdAt    DateTime @default(now()) @map("created_at")

  affiliate Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@index([affiliateId])
  @@map("referrals")
}

model AffiliateWithdrawal {
  id          String    @id @default(cuid())
  affiliateId String    @map("affiliate_id")
  amount      Int
  bankName    String    @default("") @map("bank_name")
  accountNo   String    @default("") @map("account_no")
  accountName String    @default("") @map("account_name")
  status      String    @default("pending")
  adminNotes  String    @default("") @map("admin_notes")
  createdAt   DateTime  @default(now()) @map("created_at")
  processedAt DateTime? @map("processed_at")

  affiliate Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@index([affiliateId])
  @@map("affiliate_withdrawals")
}

// ─── SUPPORT TICKETS ────────────────────────────────────────
model SupportTicket {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  subject   String
  message   String
  status    String   @default("open")
  priority  String   @default("normal")
  createdAt DateTime @default(now()) @map("created_at")
  closedAt  DateTime? @map("closed_at")

  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies TicketReply[]

  @@index([userId])
  @@map("support_tickets")
}

model TicketReply {
  id       String   @id @default(cuid())
  ticketId String   @map("ticket_id")
  userId   String   @map("user_id")
  message  String
  isAdmin  Boolean  @default(false) @map("is_admin")
  createdAt DateTime @default(now()) @map("created_at")

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("ticket_replies")
}

// ─── PASSWORD RESET TOKENS ──────────────────────────────────
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  email     String
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([token])
  @@index([userId])
  @@map("password_reset_tokens")
}

// ─── ORDERS (public order form → admin approval) ────────────
model Order {
  id            String    @id @default(cuid())
  orderNumber   String    @unique @map("order_number")
  invitationId  String?   @map("invitation_id")
  email         String
  phone         String    @default("")
  groomName     String    @map("groom_name")
  brideName     String    @map("bride_name")
  groomNickname String    @default("") @map("groom_nickname")
  brideNickname String    @default("") @map("bride_nickname")
  groomFather   String    @default("") @map("groom_father")
  groomMother   String    @default("") @map("groom_mother")
  brideFather   String    @default("") @map("bride_father")
  brideMother   String    @default("") @map("bride_mother")
  groomProfession String  @default("") @map("groom_profession")
  brideProfession String  @default("") @map("bride_profession")
  subdomain     String
  templateId    String    @map("template_id")
  packageTier   String    @map("package_tier")
  amount        Int
  uniqueCode    Int       @default(0) @map("unique_code")
  totalAmount   Int       @map("total_amount")
  proofUrl      String    @default("") @map("proof_url")
  notes         String    @default("")
  status        String    @default("pending")
  adminNotes    String    @default("") @map("admin_notes")
  referredBy    String?   @map("referred_by")
  createdAt     DateTime  @default(now()) @map("created_at")
  reviewedAt    DateTime? @map("reviewed_at")

  @@index([email])
  @@index([status])
  @@map("orders")
}

// ─── SUBSCRIPTIONS ───────────────────────────────────────────
model Subscription {
  id           String    @id @default(cuid())
  invitationId String    @map("invitation_id")
  userId       String    @map("user_id")
  orderId      String?   @map("order_id")
  tier         String
  status       String    @default("active")
  startsAt     DateTime  @map("starts_at")
  expiresAt    DateTime  @map("expires_at")
  cancelledAt  DateTime? @map("cancelled_at")
  renewedFrom  String?   @map("renewed_from")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([invitationId])
  @@index([userId])
  @@index([status])
  @@index([expiresAt])
  @@map("subscriptions")
}

// ─── A/B EXPERIMENTS ─────────────────────────────────────────
model Experiment {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String   @default("")
  variants    Json
  traffic     Int      @default(100)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  events ExperimentEvent[]

  @@map("experiments")
}

model ExperimentEvent {
  id           String   @id @default(cuid())
  experimentId String   @map("experiment_id")
  variant      String
  event        String   @default("view")
  sessionId    String   @default("") @map("session_id")
  userId       String?  @map("user_id")
  createdAt    DateTime @default(now()) @map("created_at")

  experiment Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  @@index([experimentId])
  @@index([variant])
  @@map("experiment_events")
}

// ─── USER FEEDBACK ───────────────────────────────────────────
model UserFeedback {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      String   @default("nps")
  score     Int
  comment   String   @default("")
  page      String   @default("")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([type])
  @@map("user_feedback")
}

// ─── USER REFERRALS ──────────────────────────────────────────
model UserReferral {
  id          String    @id @default(cuid())
  referrerId  String    @map("referrer_id")
  referredId  String    @map("referred_id")
  orderId     String?   @map("order_id")
  status      String    @default("pending")
  rewardType  String    @default("discount") @map("reward_type")
  rewardValue Int       @default(0) @map("reward_value")
  claimedAt   DateTime? @map("claimed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  referrer User @relation("referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referred User @relation("referred", fields: [referredId], references: [id], onDelete: Cascade)

  @@unique([referrerId, referredId])
  @@index([referrerId])
  @@index([referredId])
  @@map("user_referrals")
}

// ─── INVITATION VIEWS (analytics) ────────────────────────────
model InvitationView {
  id           String   @id @default(cuid())
  invitationId String   @map("invitation_id")
  viewedAt     DateTime @default(now()) @map("viewed_at")
  referrer     String   @default("")
  userAgent    String   @default("") @map("user_agent")
  country      String   @default("")

  invitation Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  @@index([invitationId])
  @@index([viewedAt])
  @@map("invitation_views")
}

// ─── APP SETTINGS (single row, key = "main") ─────────────────
model AppSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}
